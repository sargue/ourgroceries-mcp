{
  "name": "@sergib/ourgroceries-mcp",
  "version": "2.0.0",
  "description": "MCP server for OurGroceries.com grocery list management",
  "type": "module",
  "main": "build/index.js",
  "bin": {
    "ourgroceries-mcp": "build/cli.js"
  },
  "files": [
    "build",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "tsc -p tsconfig.test.json && node --test \"build-test/tests/**/*.test.js\"",
    "check": "npm run build && npm run lint && npm run format:check && npm test",
    "prepare": "npm run build",
    "watch": "tsc --watch"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sargue/ourgroceries-mcp.git"
  },
  "homepage": "https://github.com/sargue/ourgroceries-mcp#readme",
  "bugs": {
    "url": "https://github.com/sargue/ourgroceries-mcp/issues"
  },
  "keywords": [
    "ourgroceries",
    "grocery-list",
    "mcp",
    "model-context-protocol"
  ],
  "author": "Justin Campbell <justin@justincampbell.me>",
  "contributors": [
    "Sergi Baila <sergibaila@protonmail.com>"
  ],
  "license": "MIT",
  "engines": {
    "node": "^22.13.0 || >=24.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "commander": "^12.0.0",
    "node-fetch": "^3.3.2",
    "prompts": "^2.4.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.10.2",
    "@types/prompts": "^2.4.9",
    "eslint": "^10.3.0",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.59.1"
  }
}
